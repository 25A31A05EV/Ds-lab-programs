#include <iostream>
using namespace std;

int main()
{
    int *arr, n, i;

    cout << "Enter number of elements: ";
    cin >> n;

    // Dynamic memory allocation
    arr = new int[n];

    cout << "Enter " << n << " elements: ";
    for(i = 0; i < n; i++)
    {
        cin >> arr[i];
    }

    cout << "The elements are: ";
    for(i = 0; i < n; i++)
    {
        cout << arr[i] << " ";
    }

    // Free memory
    delete[] arr;

    return 0;
}
