#include <iostream>
using namespace std;

int main()
{
    int arr[50], n, i, key, count = 0;

    cout << "Enter number of elements: ";
    cin >> n;

    cout << "Enter elements: ";
    for(i = 0; i < n; i++)
    {
        cin >> arr[i];
    }

    cout << "Enter search key: ";
    cin >> key;

    for(i = 0; i < n; i++)
    {
        if(arr[i] == key)
        {
            count++;
        }
    }

    cout << "Number of occurrences of " << key << " = " << count;

    return 0;
}
