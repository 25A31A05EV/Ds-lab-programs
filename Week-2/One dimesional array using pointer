#include <iostream>
using namespace std;

int main()
{
    int arr[5], i;
    int *ptr;

    ptr = arr;   // pointer pointing to array

    cout << "Enter 5 elements: ";
    for(i = 0; i < 5; i++)
    {
        cin >> *(ptr + i);
    }

    cout << "Array elements are: ";
    for(i = 0; i < 5; i++)
    {
        cout << *(ptr + i) << " ";
    }

    return 0;
}
